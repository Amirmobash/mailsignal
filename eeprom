#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint16_t ENTPRELLZEIT_MS = 45;
constexpr uint16_t RESETZEIT_MS = 1200;

constexpr uint16_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_SIGNATUR = 0x6D;

struct SpeicherDaten {
  uint8_t signatur;
  uint8_t status;
  uint8_t pruefsumme;
};

class DigitalEingang {
public:
  DigitalEingang(uint8_t pin, uint16_t entprellzeit)
      : pin(pin),
        entprellzeit(entprellzeit),
        rohzustand(HIGH),
        stabilerZustand(HIGH),
        letzterStabilerZustand(HIGH),
        wechselzeit(0) {}

  void beginnen() {
    pinMode(pin, INPUT_PULLUP);

    rohzustand = digitalRead(pin);
    stabilerZustand = rohzustand;
    letzterStabilerZustand = stabilerZustand;
    wechselzeit = millis();
  }

  void aktualisieren() {
    letzterStabilerZustand = stabilerZustand;

    bool neuerRohzustand = digitalRead(pin);
    unsigned long jetzt = millis();

    if (neuerRohzustand != rohzustand) {
      rohzustand = neuerRohzustand;
      wechselzeit = jetzt;
    }

    if (
      rohzustand != stabilerZustand &&
      jetzt - wechselzeit >= entprellzeit
    ) {
      stabilerZustand = rohzustand;
    }
  }

  bool aktiv() const {
    return stabilerZustand == LOW;
  }

  bool wurdeAktiviert() const {
    return letzterStabilerZustand == HIGH &&
           stabilerZustand == LOW;
  }

  bool wurdeDeaktiviert() const {
    return letzterStabilerZustand == LOW &&
           stabilerZustand == HIGH;
  }

private:
  uint8_t pin;
  uint16_t entprellzeit;
  bool rohzustand;
  bool stabilerZustand;
  bool letzterStabilerZustand;
  unsigned long wechselzeit;
};

DigitalEingang klappenSensor(SENSOR_PIN, ENTPRELLZEIT_MS);
DigitalEingang resetTaste(RESET_PIN, ENTPRELLZEIT_MS);

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

uint8_t pruefsummeBerechnen(uint8_t status) {
  return EEPROM_SIGNATUR ^ status ^ 0xA5;
}

void ledSetzen() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  SpeicherDaten daten;

  daten.signatur = EEPROM_SIGNATUR;
  daten.status = postVorhanden ? 1 : 0;
  daten.pruefsumme = pruefsummeBerechnen(daten.status);

  SpeicherDaten gespeichert;
  EEPROM.get(EEPROM_ADRESSE, gespeichert);

  if (
    gespeichert.signatur != daten.signatur ||
    gespeichert.status != daten.status ||
    gespeichert.pruefsumme != daten.pruefsumme
  ) {
    EEPROM.put(EEPROM_ADRESSE, daten);
  }
}

void statusLaden() {
  SpeicherDaten daten;
  EEPROM.get(EEPROM_ADRESSE, daten);

  bool gueltig =
    daten.signatur == EEPROM_SIGNATUR &&
    daten.status <= 1 &&
    daten.pruefsumme == pruefsummeBerechnen(daten.status);

  if (gueltig) {
    postVorhanden = daten.status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postMelden() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ledSetzen();
}

void postBestaetigen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ledSetzen();
}

void sensorVerarbeiten() {
  klappenSensor.aktualisieren();

  if (klappenSensor.wurdeAktiviert()) {
    postMelden();
  }
}

void resetVerarbeiten() {
  resetTaste.aktualisieren();

  unsigned long jetzt = millis();

  if (resetTaste.wurdeAktiviert()) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetGestartet &&
    !resetAusgefuehrt &&
    resetTaste.aktiv() &&
    jetzt - resetStartzeit >= RESETZEIT_MS
  ) {
    postBestaetigen();
    resetAusgefuehrt = true;
  }

  if (resetTaste.wurdeDeaktiviert()) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  klappenSensor.beginnen();
  resetTaste.beginnen();

  statusLaden();
  ledSetzen();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
