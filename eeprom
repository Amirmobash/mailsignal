#include <EEPROM.h>

constexpr byte SENSOR_PIN = 2;
constexpr byte RESET_PIN = 3;
constexpr byte LED_PIN = 9;

constexpr unsigned long ENTPRELLZEIT_MS = 40;
constexpr unsigned long RESET_HALTEZEIT_MS = 900;

constexpr byte EEPROM_ADRESSE_STATUS = 0;
constexpr byte EEPROM_ADRESSE_SIGNATUR = 1;
constexpr byte EEPROM_SIGNATUR = 0x6D;

class Eingang {
public:
  Eingang(byte pin, unsigned long entprellzeit)
      : pin(pin),
        entprellzeit(entprellzeit),
        rohzustand(HIGH),
        stabilerZustand(HIGH),
        vorherigerZustand(HIGH),
        wechselzeit(0) {}

  void beginnen() {
    pinMode(pin, INPUT_PULLUP);

    rohzustand = digitalRead(pin);
    stabilerZustand = rohzustand;
    vorherigerZustand = stabilerZustand;
    wechselzeit = millis();
  }

  void aktualisieren() {
    const bool neuerRohzustand = digitalRead(pin);
    const unsigned long jetzt = millis();

    vorherigerZustand = stabilerZustand;

    if (neuerRohzustand != rohzustand) {
      rohzustand = neuerRohzustand;
      wechselzeit = jetzt;
    }

    if (
      rohzustand != stabilerZustand &&
      jetzt - wechselzeit >= entprellzeit
    ) {
      stabilerZustand = rohzustand;
    }
  }

  bool aktiv() const {
    return stabilerZustand == LOW;
  }

  bool aktiviert() const {
    return vorherigerZustand == HIGH && stabilerZustand == LOW;
  }

  bool deaktiviert() const {
    return vorherigerZustand == LOW && stabilerZustand == HIGH;
  }

private:
  byte pin;
  unsigned long entprellzeit;
  bool rohzustand;
  bool stabilerZustand;
  bool vorherigerZustand;
  unsigned long wechselzeit;
};

Eingang klappensensor(SENSOR_PIN, ENTPRELLZEIT_MS);
Eingang resetTaste(RESET_PIN, ENTPRELLZEIT_MS);

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

void ausgangAktualisieren() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  const byte neuerStatus = postVorhanden ? 1 : 0;

  EEPROM.update(EEPROM_ADRESSE_SIGNATUR, EEPROM_SIGNATUR);
  EEPROM.update(EEPROM_ADRESSE_STATUS, neuerStatus);
}

void statusLaden() {
  const bool signaturGueltig =
    EEPROM.read(EEPROM_ADRESSE_SIGNATUR) == EEPROM_SIGNATUR;

  const byte gespeicherterStatus =
    EEPROM.read(EEPROM_ADRESSE_STATUS);

  if (signaturGueltig && gespeicherterStatus <= 1) {
    postVorhanden = gespeicherterStatus == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postSetzen() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ausgangAktualisieren();
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ausgangAktualisieren();
}

void klappensensorVerarbeiten() {
  klappensensor.aktualisieren();

  if (klappensensor.aktiviert()) {
    postSetzen();
  }
}

void resetTasteVerarbeiten() {
  resetTaste.aktualisieren();

  const unsigned long jetzt = millis();

  if (resetTaste.aktiviert()) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetTaste.aktiv() &&
    resetGestartet &&
    !resetAusgefuehrt &&
    jetzt - resetStartzeit >= RESET_HALTEZEIT_MS
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (resetTaste.deaktiviert()) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  klappensensor.beginnen();
  resetTaste.beginnen();

  statusLaden();
  ausgangAktualisieren();
}

void loop() {
  klappensensorVerarbeiten();
  resetTasteVerarbeiten();
}
