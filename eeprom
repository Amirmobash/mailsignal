#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint16_t ENTPRELLZEIT_MS = 40;
constexpr uint16_t RESET_HALTEZEIT_MS = 800;

constexpr uint16_t EEPROM_ADRESSE = 0;
constexpr uint32_t SPEICHER_KENNUNG = 0x4D534947;

struct SpeicherDaten {
  uint32_t kennung;
  uint8_t postVorhanden;
  uint8_t pruefsumme;
};

struct Eingang {
  uint8_t pin;
  bool stabilerZustand;
  bool letzterRohzustand;
  unsigned long letzterWechsel;
};

Eingang sensor = {
  SENSOR_PIN,
  HIGH,
  HIGH,
  0
};

Eingang resetTaste = {
  RESET_PIN,
  HIGH,
  HIGH,
  0
};

bool postVorhanden = false;
bool sensorAusgeloest = false;
bool resetAktiv = false;

unsigned long resetStartzeit = 0;

uint8_t pruefsummeBerechnen(const SpeicherDaten& daten) {
  return static_cast<uint8_t>(
    (daten.kennung & 0xFF) ^
    ((daten.kennung >> 8) & 0xFF) ^
    ((daten.kennung >> 16) & 0xFF) ^
    ((daten.kennung >> 24) & 0xFF) ^
    daten.postVorhanden
  );
}

void statusSpeichern() {
  SpeicherDaten daten;
  daten.kennung = SPEICHER_KENNUNG;
  daten.postVorhanden = postVorhanden ? 1 : 0;
  daten.pruefsumme = pruefsummeBerechnen(daten);

  SpeicherDaten aktuell;
  EEPROM.get(EEPROM_ADRESSE, aktuell);

  if (
    aktuell.kennung != daten.kennung ||
    aktuell.postVorhanden != daten.postVorhanden ||
    aktuell.pruefsumme != daten.pruefsumme
  ) {
    EEPROM.put(EEPROM_ADRESSE, daten);
  }
}

void statusLaden() {
  SpeicherDaten daten;
  EEPROM.get(EEPROM_ADRESSE, daten);

  bool gueltig =
    daten.kennung == SPEICHER_KENNUNG &&
    daten.pruefsumme == pruefsummeBerechnen(daten) &&
    daten.postVorhanden <= 1;

  if (gueltig) {
    postVorhanden = daten.postVorhanden == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void ledAktualisieren() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void postSetzen() {
  if (!postVorhanden) {
    postVorhanden = true;
    statusSpeichern();
    ledAktualisieren();
  }
}

void postZuruecksetzen() {
  if (postVorhanden) {
    postVorhanden = false;
    statusSpeichern();
    ledAktualisieren();
  }
}

bool eingangAktualisieren(Eingang& eingang) {
  bool rohzustand = digitalRead(eingang.pin);
  unsigned long jetzt = millis();

  if (rohzustand != eingang.letzterRohzustand) {
    eingang.letzterRohzustand = rohzustand;
    eingang.letzterWechsel = jetzt;
  }

  if (
    rohzustand != eingang.stabilerZustand &&
    jetzt - eingang.letzterWechsel >= ENTPRELLZEIT_MS
  ) {
    eingang.stabilerZustand = rohzustand;
    return true;
  }

  return false;
}

void sensorVerarbeiten() {
  if (!eingangAktualisieren(sensor)) {
    return;
  }

  if (sensor.stabilerZustand == LOW) {
    if (!sensorAusgeloest) {
      sensorAusgeloest = true;
      postSetzen();
    }
  } else {
    sensorAusgeloest = false;
  }
}

void resetVerarbeiten() {
  eingangAktualisieren(resetTaste);
  unsigned long jetzt = millis();

  if (resetTaste.stabilerZustand == LOW) {
    if (!resetAktiv) {
      resetAktiv = true;
      resetStartzeit = jetzt;
    }

    if (jetzt - resetStartzeit >= RESET_HALTEZEIT_MS) {
      postZuruecksetzen();
    }
  } else {
    resetAktiv = false;
  }
}

void setup() {
  pinMode(SENSOR_PIN, INPUT_PULLUP);
  pinMode(RESET_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);

  sensor.stabilerZustand = digitalRead(SENSOR_PIN);
  sensor.letzterRohzustand = sensor.stabilerZustand;

  resetTaste.stabilerZustand = digitalRead(RESET_PIN);
  resetTaste.letzterRohzustand = resetTaste.stabilerZustand;

  statusLaden();
  ledAktualisieren();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}