#include <EEPROM.h>

constexpr byte SENSOR_PIN = 2;
constexpr byte RESET_PIN = 3;
constexpr byte LED_PIN = 9;

constexpr byte EEPROM_ADRESSE = 0;
constexpr byte STATUS_AUS = 0x35;
constexpr byte STATUS_AN = 0xCA;

constexpr unsigned long ENTPRELLZEIT_MS = 40;
constexpr unsigned long RESETZEIT_MS = 1200;
constexpr unsigned long SENSORSPERRE_MS = 500;

struct Eingang {
  byte pin;
  bool roh;
  bool stabil;
  bool vorher;
  unsigned long wechselzeit;
};

Eingang sensor;
Eingang taste;

bool postErkannt = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;
unsigned long letzterSensorimpuls = 0;

void eingangStarten(Eingang& eingang, byte pin) {
  eingang.pin = pin;

  pinMode(pin, INPUT_PULLUP);

  bool zustand = digitalRead(pin);

  eingang.roh = zustand;
  eingang.stabil = zustand;
  eingang.vorher = zustand;
  eingang.wechselzeit = millis();
}

void eingangAktualisieren(Eingang& eingang) {
  unsigned long jetzt = millis();
  bool neuerZustand = digitalRead(eingang.pin);

  eingang.vorher = eingang.stabil;

  if (neuerZustand != eingang.roh) {
    eingang.roh = neuerZustand;
    eingang.wechselzeit = jetzt;
  }

  if (
    eingang.stabil != eingang.roh &&
    jetzt - eingang.wechselzeit >= ENTPRELLZEIT_MS
  ) {
    eingang.stabil = eingang.roh;
  }
}

bool wurdeAktiviert(const Eingang& eingang) {
  return eingang.vorher == HIGH && eingang.stabil == LOW;
}

bool wurdeFreigegeben(const Eingang& eingang) {
  return eingang.vorher == LOW && eingang.stabil == HIGH;
}

bool istAktiv(const Eingang& eingang) {
  return eingang.stabil == LOW;
}

void ledAktualisieren() {
  digitalWrite(LED_PIN, postErkannt ? HIGH : LOW);
}

void statusSpeichern() {
  byte wert = postErkannt ? STATUS_AN : STATUS_AUS;

  if (EEPROM.read(EEPROM_ADRESSE) != wert) {
    EEPROM.update(EEPROM_ADRESSE, wert);
  }
}

void statusLaden() {
  byte wert = EEPROM.read(EEPROM_ADRESSE);

  if (wert == STATUS_AN) {
    postErkannt = true;
  } else {
    postErkannt = false;

    if (wert != STATUS_AUS) {
      statusSpeichern();
    }
  }
}

void postSetzen() {
  if (postErkannt) {
    return;
  }

  postErkannt = true;
  statusSpeichern();
  ledAktualisieren();
}

void postZuruecksetzen() {
  if (!postErkannt) {
    return;
  }

  postErkannt = false;
  statusSpeichern();
  ledAktualisieren();
}

void sensorVerarbeiten() {
  eingangAktualisieren(sensor);

  unsigned long jetzt = millis();

  if (
    wurdeAktiviert(sensor) &&
    jetzt - letzterSensorimpuls >= SENSORSPERRE_MS
  ) {
    letzterSensorimpuls = jetzt;
    postSetzen();
  }
}

void tasteVerarbeiten() {
  eingangAktualisieren(taste);

  unsigned long jetzt = millis();

  if (wurdeAktiviert(taste)) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetGestartet &&
    !resetAusgefuehrt &&
    istAktiv(taste) &&
    jetzt - resetStartzeit >= RESETZEIT_MS
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (wurdeFreigegeben(taste)) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  eingangStarten(sensor, SENSOR_PIN);
  eingangStarten(taste, RESET_PIN);

  statusLaden();
  ledAktualisieren();

  letzterSensorimpuls = millis() - SENSORSPERRE_MS;
}

void loop() {
  sensorVerarbeiten();
  tasteVerarbeiten();
}
