#include <EEPROM.h>

constexpr uint8_t PIN_SENSOR = 2;
constexpr uint8_t PIN_TASTE = 3;
constexpr uint8_t PIN_LED = 9;

constexpr unsigned long ENTPRELLZEIT = 35;
constexpr unsigned long RESET_DAUER = 1000;
constexpr uint8_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_MARKIERUNG = 0xA7;

struct Speicher {
  uint8_t markierung;
  uint8_t status;
  uint8_t pruefung;
};

class EntprellterEingang {
public:
  EntprellterEingang(uint8_t pin, unsigned long entprellzeit)
      : pin_(pin),
        entprellzeit_(entprellzeit),
        rohzustand_(HIGH),
        stabilerZustand_(HIGH),
        vorherigerZustand_(HIGH),
        wechselzeit_(0) {}

  void starten() {
    pinMode(pin_, INPUT_PULLUP);
    rohzustand_ = digitalRead(pin_);
    stabilerZustand_ = rohzustand_;
    vorherigerZustand_ = stabilerZustand_;
    wechselzeit_ = millis();
  }

  void aktualisieren() {
    bool aktuellerRohzustand = digitalRead(pin_);
    unsigned long jetzt = millis();

    vorherigerZustand_ = stabilerZustand_;

    if (aktuellerRohzustand != rohzustand_) {
      rohzustand_ = aktuellerRohzustand;
      wechselzeit_ = jetzt;
    }

    if (
      stabilerZustand_ != rohzustand_ &&
      jetzt - wechselzeit_ >= entprellzeit_
    ) {
      stabilerZustand_ = rohzustand_;
    }
  }

  bool gedrueckt() const {
    return stabilerZustand_ == LOW;
  }

  bool fallendeFlanke() const {
    return vorherigerZustand_ == HIGH && stabilerZustand_ == LOW;
  }

  bool steigendeFlanke() const {
    return vorherigerZustand_ == LOW && stabilerZustand_ == HIGH;
  }

private:
  uint8_t pin_;
  unsigned long entprellzeit_;
  bool rohzustand_;
  bool stabilerZustand_;
  bool vorherigerZustand_;
  unsigned long wechselzeit_;
};

EntprellterEingang sensor(PIN_SENSOR, ENTPRELLZEIT);
EntprellterEingang taste(PIN_TASTE, ENTPRELLZEIT);

bool postStatus = false;
bool resetLaeuft = false;
bool resetAusgefuehrt = false;

unsigned long resetStart = 0;

uint8_t pruefungBerechnen(uint8_t status) {
  return EEPROM_MARKIERUNG ^ status ^ 0x5C;
}

void statusAnzeigen() {
  digitalWrite(PIN_LED, postStatus ? HIGH : LOW);
}

void statusSpeichern() {
  Speicher neu;

  neu.markierung = EEPROM_MARKIERUNG;
  neu.status = postStatus ? 1 : 0;
  neu.pruefung = pruefungBerechnen(neu.status);

  Speicher alt;
  EEPROM.get(EEPROM_ADRESSE, alt);

  if (
    alt.markierung != neu.markierung ||
    alt.status != neu.status ||
    alt.pruefung != neu.pruefung
  ) {
    EEPROM.put(EEPROM_ADRESSE, neu);
  }
}

void statusLaden() {
  Speicher daten;
  EEPROM.get(EEPROM_ADRESSE, daten);

  bool gueltig =
    daten.markierung == EEPROM_MARKIERUNG &&
    daten.status <= 1 &&
    daten.pruefung == pruefungBerechnen(daten.status);

  postStatus = gueltig && daten.status == 1;

  if (!gueltig) {
    statusSpeichern();
  }
}

void postRegistrieren() {
  if (postStatus) {
    return;
  }

  postStatus = true;
  statusSpeichern();
  statusAnzeigen();
}

void postLoeschen() {
  if (!postStatus) {
    return;
  }

  postStatus = false;
  statusSpeichern();
  statusAnzeigen();
}

void sensorPruefen() {
  sensor.aktualisieren();

  if (sensor.fallendeFlanke()) {
    postRegistrieren();
  }
}

void tastePruefen() {
  taste.aktualisieren();

  unsigned long jetzt = millis();

  if (taste.fallendeFlanke()) {
    resetLaeuft = true;
    resetAusgefuehrt = false;
    resetStart = jetzt;
  }

  if (
    taste.gedrueckt() &&
    resetLaeuft &&
    !resetAusgefuehrt &&
    jetzt - resetStart >= RESET_DAUER
  ) {
    postLoeschen();
    resetAusgefuehrt = true;
  }

  if (taste.steigendeFlanke()) {
    resetLaeuft = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(PIN_LED, OUTPUT);

  sensor.starten();
  taste.starten();

  statusLaden();
  statusAnzeigen();
}

void loop() {
  sensorPruefen();
  tastePruefen();
}