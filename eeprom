#include <EEPROM.h>

constexpr byte SENSOR_PIN = 2;
constexpr byte RESET_PIN = 3;
constexpr byte LED_PIN = 9;

constexpr byte EEPROM_STATUS_ADRESSE = 0;
constexpr byte EEPROM_SIGNATUR_ADRESSE = 1;
constexpr byte EEPROM_SIGNATUR = 0x6D;

constexpr unsigned long ENTPRELLZEIT_MS = 40;
constexpr unsigned long RESET_HALTEZEIT_MS = 1200;
constexpr unsigned long LED_TESTZEIT_MS = 500;

class DigitalEingang {
public:
  DigitalEingang(byte pin, unsigned long entprellzeit)
    : pin_(pin),
      entprellzeit_(entprellzeit),
      rohzustand_(HIGH),
      stabilerZustand_(HIGH),
      vorherigerZustand_(HIGH),
      wechselzeit_(0) {}

  void beginnen() {
    pinMode(pin_, INPUT_PULLUP);

    bool zustand = digitalRead(pin_);

    rohzustand_ = zustand;
    stabilerZustand_ = zustand;
    vorherigerZustand_ = zustand;
    wechselzeit_ = millis();
  }

  void aktualisieren() {
    vorherigerZustand_ = stabilerZustand_;

    bool neuerRohzustand = digitalRead(pin_);
    unsigned long jetzt = millis();

    if (neuerRohzustand != rohzustand_) {
      rohzustand_ = neuerRohzustand;
      wechselzeit_ = jetzt;
    }

    if (
      rohzustand_ != stabilerZustand_ &&
      jetzt - wechselzeit_ >= entprellzeit_
    ) {
      stabilerZustand_ = rohzustand_;
    }
  }

  bool aktiv() const {
    return stabilerZustand_ == LOW;
  }

  bool wurdeAktiviert() const {
    return vorherigerZustand_ == HIGH &&
           stabilerZustand_ == LOW;
  }

  bool wurdeDeaktiviert() const {
    return vorherigerZustand_ == LOW &&
           stabilerZustand_ == HIGH;
  }

private:
  byte pin_;
  unsigned long entprellzeit_;
  bool rohzustand_;
  bool stabilerZustand_;
  bool vorherigerZustand_;
  unsigned long wechselzeit_;
};

DigitalEingang klappensensor(SENSOR_PIN, ENTPRELLZEIT_MS);
DigitalEingang resetTaste(RESET_PIN, ENTPRELLZEIT_MS);

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

void ledSetzen(bool aktiv) {
  digitalWrite(LED_PIN, aktiv ? HIGH : LOW);
}

void statusSpeichern() {
  EEPROM.update(
    EEPROM_STATUS_ADRESSE,
    postVorhanden ? 1 : 0
  );

  EEPROM.update(
    EEPROM_SIGNATUR_ADRESSE,
    EEPROM_SIGNATUR
  );
}

void statusLaden() {
  byte signatur = EEPROM.read(EEPROM_SIGNATUR_ADRESSE);
  byte status = EEPROM.read(EEPROM_STATUS_ADRESSE);

  if (signatur == EEPROM_SIGNATUR && status <= 1) {
    postVorhanden = status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postMelden() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ledSetzen(true);
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ledSetzen(false);
}

void sensorVerarbeiten() {
  klappensensor.aktualisieren();

  if (klappensensor.wurdeAktiviert()) {
    postMelden();
  }
}

void resetVerarbeiten() {
  resetTaste.aktualisieren();

  unsigned long jetzt = millis();

  if (resetTaste.wurdeAktiviert()) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetGestartet &&
    resetTaste.aktiv() &&
    !resetAusgefuehrt &&
    jetzt - resetStartzeit >= RESET_HALTEZEIT_MS
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (resetTaste.wurdeDeaktiviert()) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void startTest() {
  ledSetzen(true);
  delay(LED_TESTZEIT_MS);
  ledSetzen(false);
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  klappensensor.beginnen();
  resetTaste.beginnen();

  startTest();
  statusLaden();
  ledSetzen(postVorhanden);
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
