#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint8_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_SIGNATUR = 0x6D;

constexpr unsigned long ENTPRELLZEIT_MS = 40;
constexpr unsigned long RESETZEIT_MS = 80;

struct Eingang {
  uint8_t pin;
  bool roh;
  bool stabil;
  bool vorher;
  unsigned long wechselzeit;
};

Eingang sensor;
Eingang resetTaste;

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

void eingangStarten(Eingang& eingang, uint8_t pin) {
  eingang.pin = pin;

  pinMode(pin, INPUT_PULLUP);

  bool zustand = digitalRead(pin);

  eingang.roh = zustand;
  eingang.stabil = zustand;
  eingang.vorher = zustand;
  eingang.wechselzeit = millis();
}

void eingangAktualisieren(Eingang& eingang) {
  bool aktuellerZustand = digitalRead(eingang.pin);
  unsigned long jetzt = millis();

  eingang.vorher = eingang.stabil;

  if (aktuellerZustand != eingang.roh) {
    eingang.roh = aktuellerZustand;
    eingang.wechselzeit = jetzt;
  }

  if (
    eingang.stabil != eingang.roh &&
    jetzt - eingang.wechselzeit >= ENTPRELLZEIT_MS
  ) {
    eingang.stabil = eingang.roh;
  }
}

bool wurdeAktiviert(const Eingang& eingang) {
  return eingang.vorher == HIGH && eingang.stabil == LOW;
}

bool wurdeLosgelassen(const Eingang& eingang) {
  return eingang.vorher == LOW && eingang.stabil == HIGH;
}

bool istAktiv(const Eingang& eingang) {
  return eingang.stabil == LOW;
}

uint8_t pruefsumme(uint8_t status) {
  return EEPROM_SIGNATUR ^ status ^ 0xA5;
}

void statusAnzeigen() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  uint8_t status = postVorhanden ? 1 : 0;

  EEPROM.update(EEPROM_ADRESSE, EEPROM_SIGNATUR);
  EEPROM.update(EEPROM_ADRESSE + 1, status);
  EEPROM.update(EEPROM_ADRESSE + 2, pruefsumme(status));
}

void statusLaden() {
  uint8_t signatur = EEPROM.read(EEPROM_ADRESSE);
  uint8_t status = EEPROM.read(EEPROM_ADRESSE + 1);
  uint8_t kontrolle = EEPROM.read(EEPROM_ADRESSE + 2);

  bool gueltig =
    signatur == EEPROM_SIGNATUR &&
    status <= 1 &&
    kontrolle == pruefsumme(status);

  if (gueltig) {
    postVorhanden = status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postSetzen() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  statusAnzeigen();
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  statusAnzeigen();
}

void sensorBearbeiten() {
  eingangAktualisieren(sensor);

  if (wurdeAktiviert(sensor)) {
    postSetzen();
  }
}

void resetBearbeiten() {
  eingangAktualisieren(resetTaste);

  unsigned long jetzt = millis();

  if (wurdeAktiviert(resetTaste)) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetGestartet &&
    !resetAusgefuehrt &&
    istAktiv(resetTaste) &&
    jetzt - resetStartzeit >= RESETZEIT_MS
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (wurdeLosgelassen(resetTaste)) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  eingangStarten(sensor, SENSOR_PIN);
  eingangStarten(resetTaste, RESET_PIN);

  statusLaden();
  statusAnzeigen();
}

void loop() {
  sensorBearbeiten();
  resetBearbeiten();
}
