#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint8_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_SIGNATURE = 0xB6;

constexpr unsigned long SENSOR_ENTPRELLUNG_MS = 60;
constexpr unsigned long TASTE_ENTPRELLUNG_MS = 40;
constexpr unsigned long RESET_HALTEZEIT_MS = 1200;

struct Speicherblock {
  uint8_t signatur;
  uint8_t status;
  uint8_t kontrollwert;
};

class Eingang {
public:
  Eingang(uint8_t pin, unsigned long entprellzeit)
      : pin(pin),
        entprellzeit(entprellzeit),
        rohzustand(HIGH),
        stabilerZustand(HIGH),
        letzterStabilerZustand(HIGH),
        wechselzeit(0) {}

  void beginnen() {
    pinMode(pin, INPUT_PULLUP);

    rohzustand = digitalRead(pin);
    stabilerZustand = rohzustand;
    letzterStabilerZustand = stabilerZustand;
    wechselzeit = millis();
  }

  void aktualisieren() {
    letzterStabilerZustand = stabilerZustand;

    bool neuerRohzustand = digitalRead(pin);
    unsigned long jetzt = millis();

    if (neuerRohzustand != rohzustand) {
      rohzustand = neuerRohzustand;
      wechselzeit = jetzt;
    }

    if (
      rohzustand != stabilerZustand &&
      jetzt - wechselzeit >= entprellzeit
    ) {
      stabilerZustand = rohzustand;
    }
  }

  bool aktiv() const {
    return stabilerZustand == LOW;
  }

  bool aktiviert() const {
    return letzterStabilerZustand == HIGH &&
           stabilerZustand == LOW;
  }

  bool deaktiviert() const {
    return letzterStabilerZustand == LOW &&
           stabilerZustand == HIGH;
  }

private:
  uint8_t pin;
  unsigned long entprellzeit;
  bool rohzustand;
  bool stabilerZustand;
  bool letzterStabilerZustand;
  unsigned long wechselzeit;
};

Eingang briefSensor(SENSOR_PIN, SENSOR_ENTPRELLUNG_MS);
Eingang resetTaste(RESET_PIN, TASTE_ENTPRELLUNG_MS);

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

uint8_t kontrollwertBerechnen(uint8_t status) {
  return static_cast<uint8_t>(
    EEPROM_SIGNATURE ^
    status ^
    0x39
  );
}

void anzeigeAktualisieren() {
  digitalWrite(
    LED_PIN,
    postVorhanden ? HIGH : LOW
  );
}

void statusSpeichern() {
  Speicherblock daten;

  daten.signatur = EEPROM_SIGNATURE;
  daten.status = postVorhanden ? 1 : 0;
  daten.kontrollwert = kontrollwertBerechnen(daten.status);

  Speicherblock gespeichert;
  EEPROM.get(EEPROM_ADRESSE, gespeichert);

  if (
    gespeichert.signatur != daten.signatur ||
    gespeichert.status != daten.status ||
    gespeichert.kontrollwert != daten.kontrollwert
  ) {
    EEPROM.put(EEPROM_ADRESSE, daten);
  }
}

void statusLaden() {
  Speicherblock daten;
  EEPROM.get(EEPROM_ADRESSE, daten);

  bool gueltig =
    daten.signatur == EEPROM_SIGNATURE &&
    daten.status <= 1 &&
    daten.kontrollwert ==
      kontrollwertBerechnen(daten.status);

  if (gueltig) {
    postVorhanden = daten.status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postMelden() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;

  statusSpeichern();
  anzeigeAktualisieren();
}

void postBestaetigen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;

  statusSpeichern();
  anzeigeAktualisieren();
}

void sensorVerarbeiten() {
  briefSensor.aktualisieren();

  if (briefSensor.aktiviert()) {
    postMelden();
  }
}

void resetVerarbeiten() {
  resetTaste.aktualisieren();

  unsigned long jetzt = millis();

  if (resetTaste.aktiviert()) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetGestartet &&
    resetTaste.aktiv() &&
    !resetAusgefuehrt &&
    jetzt - resetStartzeit >= RESET_HALTEZEIT_MS
  ) {
    postBestaetigen();
    resetAusgefuehrt = true;
  }

  if (resetTaste.deaktiviert()) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  briefSensor.beginnen();
  resetTaste.beginnen();

  statusLaden();
  anzeigeAktualisieren();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
