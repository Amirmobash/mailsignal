#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr unsigned long ENTPRELL_MS = 40;
constexpr unsigned long RESET_HALTE_MS = 1000;

constexpr uint8_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_SCHLUESSEL = 0x6D;

struct Eingang {
  uint8_t pin;
  bool roh;
  bool stabil;
  bool vorher;
  unsigned long wechselZeit;
};

Eingang sensor;
Eingang resetTaste;

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartZeit = 0;

void eingangStarten(Eingang& eingang, uint8_t pin) {
  eingang.pin = pin;

  pinMode(pin, INPUT_PULLUP);

  bool zustand = digitalRead(pin);

  eingang.roh = zustand;
  eingang.stabil = zustand;
  eingang.vorher = zustand;
  eingang.wechselZeit = millis();
}

void eingangAktualisieren(Eingang& eingang) {
  unsigned long jetzt = millis();
  bool neuerRohzustand = digitalRead(eingang.pin);

  eingang.vorher = eingang.stabil;

  if (neuerRohzustand != eingang.roh) {
    eingang.roh = neuerRohzustand;
    eingang.wechselZeit = jetzt;
  }

  if (
    eingang.stabil != eingang.roh &&
    jetzt - eingang.wechselZeit >= ENTPRELL_MS
  ) {
    eingang.stabil = eingang.roh;
  }
}

bool wurdeAktiviert(const Eingang& eingang) {
  return eingang.vorher == HIGH && eingang.stabil == LOW;
}

bool wurdeFreigegeben(const Eingang& eingang) {
  return eingang.vorher == LOW && eingang.stabil == HIGH;
}

void ledAktualisieren() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  uint8_t wert = postVorhanden ? 1 : 0;
  uint8_t pruefwert = EEPROM_SCHLUESSEL ^ wert;

  EEPROM.update(EEPROM_ADRESSE, EEPROM_SCHLUESSEL);
  EEPROM.update(EEPROM_ADRESSE + 1, wert);
  EEPROM.update(EEPROM_ADRESSE + 2, pruefwert);
}

void statusLaden() {
  uint8_t schluessel = EEPROM.read(EEPROM_ADRESSE);
  uint8_t wert = EEPROM.read(EEPROM_ADRESSE + 1);
  uint8_t pruefwert = EEPROM.read(EEPROM_ADRESSE + 2);

  bool gueltig =
    schluessel == EEPROM_SCHLUESSEL &&
    wert <= 1 &&
    pruefwert == (EEPROM_SCHLUESSEL ^ wert);

  if (gueltig) {
    postVorhanden = wert == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postSetzen() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ledAktualisieren();
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ledAktualisieren();
}

void sensorVerarbeiten() {
  eingangAktualisieren(sensor);

  if (wurdeAktiviert(sensor)) {
    postSetzen();
  }
}

void resetVerarbeiten() {
  eingangAktualisieren(resetTaste);

  unsigned long jetzt = millis();

  if (wurdeAktiviert(resetTaste)) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartZeit = jetzt;
  }

  if (
    resetGestartet &&
    !resetAusgefuehrt &&
    resetTaste.stabil == LOW &&
    jetzt - resetStartZeit >= RESET_HALTE_MS
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (wurdeFreigegeben(resetTaste)) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  eingangStarten(sensor, SENSOR_PIN);
  eingangStarten(resetTaste, RESET_PIN);

  statusLaden();
  ledAktualisieren();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
