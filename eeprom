#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint16_t ENTPRELLZEIT_MS = 40;
constexpr uint16_t RESET_HALTEZEIT_MS = 1200;

constexpr int EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_SIGNATUR = 0xB6;

struct Speicherzustand {
  uint8_t signatur;
  uint8_t post;
  uint8_t pruefsumme;
};

class DigitalerEingang {
public:
  DigitalerEingang(uint8_t pin, uint16_t entprellzeit)
      : pin(pin),
        entprellzeit(entprellzeit),
        rohzustand(HIGH),
        stabilerZustand(HIGH),
        letzterStabilerZustand(HIGH),
        wechselzeit(0) {}

  void beginnen() {
    pinMode(pin, INPUT_PULLUP);

    rohzustand = digitalRead(pin);
    stabilerZustand = rohzustand;
    letzterStabilerZustand = stabilerZustand;
    wechselzeit = millis();
  }

  void aktualisieren() {
    letzterStabilerZustand = stabilerZustand;

    bool neuerRohzustand = digitalRead(pin);
    unsigned long jetzt = millis();

    if (neuerRohzustand != rohzustand) {
      rohzustand = neuerRohzustand;
      wechselzeit = jetzt;
    }

    if (
      rohzustand != stabilerZustand &&
      jetzt - wechselzeit >= entprellzeit
    ) {
      stabilerZustand = rohzustand;
    }
  }

  bool aktiv() const {
    return stabilerZustand == LOW;
  }

  bool wurdeAktiviert() const {
    return letzterStabilerZustand == HIGH &&
           stabilerZustand == LOW;
  }

  bool wurdeDeaktiviert() const {
    return letzterStabilerZustand == LOW &&
           stabilerZustand == HIGH;
  }

private:
  uint8_t pin;
  uint16_t entprellzeit;
  bool rohzustand;
  bool stabilerZustand;
  bool letzterStabilerZustand;
  unsigned long wechselzeit;
};

DigitalerEingang einwurfsensor(SENSOR_PIN, ENTPRELLZEIT_MS);
DigitalerEingang rueckstelltaste(RESET_PIN, ENTPRELLZEIT_MS);

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

uint8_t pruefsummeErzeugen(uint8_t status) {
  return EEPROM_SIGNATUR ^ status ^ 0x3D;
}

void ledSetzen() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void zustandSpeichern() {
  Speicherzustand neuerZustand;

  neuerZustand.signatur = EEPROM_SIGNATUR;
  neuerZustand.post = postVorhanden ? 1 : 0;
  neuerZustand.pruefsumme =
      pruefsummeErzeugen(neuerZustand.post);

  Speicherzustand gespeicherterZustand;
  EEPROM.get(EEPROM_ADRESSE, gespeicherterZustand);

  bool identisch =
      gespeicherterZustand.signatur ==
          neuerZustand.signatur &&
      gespeicherterZustand.post ==
          neuerZustand.post &&
      gespeicherterZustand.pruefsumme ==
          neuerZustand.pruefsumme;

  if (!identisch) {
    EEPROM.put(EEPROM_ADRESSE, neuerZustand);
  }
}

void zustandLaden() {
  Speicherzustand gespeicherterZustand;
  EEPROM.get(EEPROM_ADRESSE, gespeicherterZustand);

  bool gueltig =
      gespeicherterZustand.signatur ==
          EEPROM_SIGNATUR &&
      gespeicherterZustand.post <= 1 &&
      gespeicherterZustand.pruefsumme ==
          pruefsummeErzeugen(
              gespeicherterZustand.post
          );

  if (gueltig) {
    postVorhanden =
        gespeicherterZustand.post == 1;
  } else {
    postVorhanden = false;
    zustandSpeichern();
  }
}

void postMelden() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  zustandSpeichern();
  ledSetzen();
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  zustandSpeichern();
  ledSetzen();
}

void sensorVerarbeiten() {
  einwurfsensor.aktualisieren();

  if (einwurfsensor.wurdeAktiviert()) {
    postMelden();
  }
}

void resetVerarbeiten() {
  rueckstelltaste.aktualisieren();

  unsigned long jetzt = millis();

  if (rueckstelltaste.wurdeAktiviert()) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetGestartet &&
    !resetAusgefuehrt &&
    rueckstelltaste.aktiv() &&
    jetzt - resetStartzeit >= RESET_HALTEZEIT_MS
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (rueckstelltaste.wurdeDeaktiviert()) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  einwurfsensor.beginnen();
  rueckstelltaste.beginnen();

  zustandLaden();
  ledSetzen();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
