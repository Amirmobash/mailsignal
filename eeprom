#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint8_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_SIGNATUR = 0x6D;

constexpr unsigned long SENSOR_ENTPRELLZEIT = 40;
constexpr unsigned long TASTER_ENTPRELLZEIT = 40;
constexpr unsigned long RESET_HALTEZEIT = 1000;

struct Eingang {
  uint8_t pin;
  bool roh;
  bool stabil;
  bool vorher;
  unsigned long wechselzeit;
  unsigned long entprellzeit;
};

struct Speicher {
  uint8_t signatur;
  uint8_t status;
  uint8_t pruefsumme;
};

Eingang sensor = {
  SENSOR_PIN,
  HIGH,
  HIGH,
  HIGH,
  0,
  SENSOR_ENTPRELLZEIT
};

Eingang resetTaster = {
  RESET_PIN,
  HIGH,
  HIGH,
  HIGH,
  0,
  TASTER_ENTPRELLZEIT
};

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

uint8_t pruefsummeBerechnen(uint8_t status) {
  return EEPROM_SIGNATUR ^ status ^ 0xA5;
}

void eingangStarten(Eingang& eingang) {
  pinMode(eingang.pin, INPUT_PULLUP);

  bool zustand = digitalRead(eingang.pin);

  eingang.roh = zustand;
  eingang.stabil = zustand;
  eingang.vorher = zustand;
  eingang.wechselzeit = millis();
}

void eingangAktualisieren(Eingang& eingang) {
  unsigned long jetzt = millis();
  bool aktuellerZustand = digitalRead(eingang.pin);

  eingang.vorher = eingang.stabil;

  if (aktuellerZustand != eingang.roh) {
    eingang.roh = aktuellerZustand;
    eingang.wechselzeit = jetzt;
  }

  if (
    eingang.stabil != eingang.roh &&
    jetzt - eingang.wechselzeit >= eingang.entprellzeit
  ) {
    eingang.stabil = eingang.roh;
  }
}

bool fallendeFlanke(const Eingang& eingang) {
  return eingang.vorher == HIGH && eingang.stabil == LOW;
}

bool steigendeFlanke(const Eingang& eingang) {
  return eingang.vorher == LOW && eingang.stabil == HIGH;
}

bool aktiv(const Eingang& eingang) {
  return eingang.stabil == LOW;
}

void ledAktualisieren() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  Speicher neu;

  neu.signatur = EEPROM_SIGNATUR;
  neu.status = postVorhanden ? 1 : 0;
  neu.pruefsumme = pruefsummeBerechnen(neu.status);

  Speicher alt;
  EEPROM.get(EEPROM_ADRESSE, alt);

  if (
    alt.signatur != neu.signatur ||
    alt.status != neu.status ||
    alt.pruefsumme != neu.pruefsumme
  ) {
    EEPROM.put(EEPROM_ADRESSE, neu);
  }
}

void statusLaden() {
  Speicher daten;
  EEPROM.get(EEPROM_ADRESSE, daten);

  bool gueltig =
    daten.signatur == EEPROM_SIGNATUR &&
    daten.status <= 1 &&
    daten.pruefsumme == pruefsummeBerechnen(daten.status);

  if (gueltig) {
    postVorhanden = daten.status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postSetzen() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ledAktualisieren();
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ledAktualisieren();
}

void sensorVerarbeiten() {
  eingangAktualisieren(sensor);

  if (fallendeFlanke(sensor)) {
    postSetzen();
  }
}

void resetVerarbeiten() {
  eingangAktualisieren(resetTaster);

  unsigned long jetzt = millis();

  if (fallendeFlanke(resetTaster)) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    aktiv(resetTaster) &&
    resetGestartet &&
    !resetAusgefuehrt &&
    jetzt - resetStartzeit >= RESET_HALTEZEIT
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (steigendeFlanke(resetTaster)) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  eingangStarten(sensor);
  eingangStarten(resetTaster);

  statusLaden();
  ledAktualisieren();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
