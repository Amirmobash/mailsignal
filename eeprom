#include <EEPROM.h>

constexpr byte SENSOR_PIN = 2;
constexpr byte RESET_PIN = 3;
constexpr byte LED_PIN = 9;

constexpr unsigned long ENTPRELLZEIT_MS = 40;
constexpr unsigned long RESETZEIT_MS = 1000;

constexpr int EEPROM_ADRESSE = 0;
constexpr byte EEPROM_SIGNATUR = 0xB6;

struct Speicherwert {
  byte signatur;
  byte status;
  byte pruefung;
};

class Eingang {
public:
  Eingang(byte pin, unsigned long entprellzeit)
      : pin(pin),
        entprellzeit(entprellzeit),
        rohzustand(HIGH),
        stabilerZustand(HIGH),
        vorherigerZustand(HIGH),
        wechselzeit(0) {}

  void beginnen() {
    pinMode(pin, INPUT_PULLUP);
    rohzustand = digitalRead(pin);
    stabilerZustand = rohzustand;
    vorherigerZustand = stabilerZustand;
    wechselzeit = millis();
  }

  void aktualisieren() {
    vorherigerZustand = stabilerZustand;

    bool aktuellerZustand = digitalRead(pin);
    unsigned long jetzt = millis();

    if (aktuellerZustand != rohzustand) {
      rohzustand = aktuellerZustand;
      wechselzeit = jetzt;
    }

    if (
      rohzustand != stabilerZustand &&
      jetzt - wechselzeit >= entprellzeit
    ) {
      stabilerZustand = rohzustand;
    }
  }

  bool aktiv() const {
    return stabilerZustand == LOW;
  }

  bool aktiviert() const {
    return vorherigerZustand == HIGH && stabilerZustand == LOW;
  }

  bool deaktiviert() const {
    return vorherigerZustand == LOW && stabilerZustand == HIGH;
  }

private:
  byte pin;
  unsigned long entprellzeit;
  bool rohzustand;
  bool stabilerZustand;
  bool vorherigerZustand;
  unsigned long wechselzeit;
};

Eingang sensor(SENSOR_PIN, ENTPRELLZEIT_MS);
Eingang resetTaste(RESET_PIN, ENTPRELLZEIT_MS);

bool postVorhanden = false;
bool resetMessungAktiv = false;
bool resetBereitsAusgefuehrt = false;

unsigned long resetStartzeit = 0;

byte pruefungBerechnen(byte status) {
  return EEPROM_SIGNATUR ^ status ^ 0x69;
}

void ledSetzen() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  Speicherwert neuerWert;

  neuerWert.signatur = EEPROM_SIGNATUR;
  neuerWert.status = postVorhanden ? 1 : 0;
  neuerWert.pruefung = pruefungBerechnen(neuerWert.status);

  Speicherwert alterWert;
  EEPROM.get(EEPROM_ADRESSE, alterWert);

  if (
    alterWert.signatur != neuerWert.signatur ||
    alterWert.status != neuerWert.status ||
    alterWert.pruefung != neuerWert.pruefung
  ) {
    EEPROM.put(EEPROM_ADRESSE, neuerWert);
  }
}

void statusLaden() {
  Speicherwert wert;
  EEPROM.get(EEPROM_ADRESSE, wert);

  bool gueltig =
    wert.signatur == EEPROM_SIGNATUR &&
    wert.status <= 1 &&
    wert.pruefung == pruefungBerechnen(wert.status);

  if (gueltig) {
    postVorhanden = wert.status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postAktivieren() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ledSetzen();
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ledSetzen();
}

void sensorVerarbeiten() {
  sensor.aktualisieren();

  if (sensor.aktiviert()) {
    postAktivieren();
  }
}

void resetVerarbeiten() {
  resetTaste.aktualisieren();

  unsigned long jetzt = millis();

  if (resetTaste.aktiviert()) {
    resetMessungAktiv = true;
    resetBereitsAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetTaste.aktiv() &&
    resetMessungAktiv &&
    !resetBereitsAusgefuehrt &&
    jetzt - resetStartzeit >= RESETZEIT_MS
  ) {
    postZuruecksetzen();
    resetBereitsAusgefuehrt = true;
  }

  if (resetTaste.deaktiviert()) {
    resetMessungAktiv = false;
    resetBereitsAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  sensor.beginnen();
  resetTaste.beginnen();

  statusLaden();
  ledSetzen();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
