#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint8_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_KENNUNG = 0xB4;

constexpr unsigned long ENTPRELLZEIT_MS = 40;
constexpr unsigned long RESETZEIT_MS = 1000;

struct SpeicherDaten {
  uint8_t kennung;
  uint8_t status;
  uint8_t pruefsumme;
};

class DigitalEingang {
public:
  DigitalEingang(uint8_t pin, unsigned long entprellzeit)
      : pin(pin),
        entprellzeit(entprellzeit),
        rohzustand(HIGH),
        zustand(HIGH),
        vorherigerZustand(HIGH),
        wechselzeit(0) {}

  void starten() {
    pinMode(pin, INPUT_PULLUP);

    rohzustand = digitalRead(pin);
    zustand = rohzustand;
    vorherigerZustand = zustand;
    wechselzeit = millis();
  }

  void aktualisieren() {
    bool neuerRohzustand = digitalRead(pin);
    unsigned long jetzt = millis();

    vorherigerZustand = zustand;

    if (neuerRohzustand != rohzustand) {
      rohzustand = neuerRohzustand;
      wechselzeit = jetzt;
    }

    if (
      rohzustand != zustand &&
      jetzt - wechselzeit >= entprellzeit
    ) {
      zustand = rohzustand;
    }
  }

  bool istAktiv() const {
    return zustand == LOW;
  }

  bool wurdeAktiviert() const {
    return vorherigerZustand == HIGH && zustand == LOW;
  }

  bool wurdeDeaktiviert() const {
    return vorherigerZustand == LOW && zustand == HIGH;
  }

private:
  uint8_t pin;
  unsigned long entprellzeit;
  bool rohzustand;
  bool zustand;
  bool vorherigerZustand;
  unsigned long wechselzeit;
};

DigitalEingang klappenSensor(SENSOR_PIN, ENTPRELLZEIT_MS);
DigitalEingang resetTaste(RESET_PIN, ENTPRELLZEIT_MS);

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

uint8_t pruefsummeErstellen(uint8_t status) {
  return EEPROM_KENNUNG ^ status ^ 0x6D;
}

void ledAktualisieren() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  SpeicherDaten daten;

  daten.kennung = EEPROM_KENNUNG;
  daten.status = postVorhanden ? 1 : 0;
  daten.pruefsumme = pruefsummeErstellen(daten.status);

  SpeicherDaten gespeichert;
  EEPROM.get(EEPROM_ADRESSE, gespeichert);

  bool unveraendert =
    gespeichert.kennung == daten.kennung &&
    gespeichert.status == daten.status &&
    gespeichert.pruefsumme == daten.pruefsumme;

  if (!unveraendert) {
    EEPROM.put(EEPROM_ADRESSE, daten);
  }
}

void statusLaden() {
  SpeicherDaten daten;
  EEPROM.get(EEPROM_ADRESSE, daten);

  bool gueltig =
    daten.kennung == EEPROM_KENNUNG &&
    daten.status <= 1 &&
    daten.pruefsumme == pruefsummeErstellen(daten.status);

  if (gueltig) {
    postVorhanden = daten.status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postMelden() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ledAktualisieren();
}

void postBestaetigen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ledAktualisieren();
}

void sensorVerarbeiten() {
  klappenSensor.aktualisieren();

  if (klappenSensor.wurdeAktiviert()) {
    postMelden();
  }
}

void resetVerarbeiten() {
  resetTaste.aktualisieren();

  unsigned long jetzt = millis();

  if (resetTaste.wurdeAktiviert()) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetTaste.istAktiv() &&
    resetGestartet &&
    !resetAusgefuehrt &&
    jetzt - resetStartzeit >= RESETZEIT_MS
  ) {
    postBestaetigen();
    resetAusgefuehrt = true;
  }

  if (resetTaste.wurdeDeaktiviert()) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  klappenSensor.starten();
  resetTaste.starten();

  statusLaden();
  ledAktualisieren();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
