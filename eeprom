#include <EEPROM.h>

constexpr uint8_t SENSOR_PIN = 2;
constexpr uint8_t RESET_PIN = 3;
constexpr uint8_t LED_PIN = 9;

constexpr uint8_t EEPROM_ADRESSE = 0;
constexpr uint8_t EEPROM_SIGNATUR = 0xB6;

constexpr unsigned long ENTPRELLZEIT_MS = 40;
constexpr unsigned long RESETZEIT_MS = 1200;

struct Speicherwert {
  uint8_t signatur;
  uint8_t status;
  uint8_t kontrolle;
};

class Eingang {
public:
  Eingang(uint8_t pin, unsigned long entprellzeit)
      : pin(pin),
        entprellzeit(entprellzeit),
        rohzustand(HIGH),
        zustand(HIGH),
        vorherigerZustand(HIGH),
        wechselzeit(0) {}

  void beginnen() {
    pinMode(pin, INPUT_PULLUP);
    rohzustand = digitalRead(pin);
    zustand = rohzustand;
    vorherigerZustand = zustand;
    wechselzeit = millis();
  }

  void aktualisieren() {
    bool neuerRohzustand = digitalRead(pin);
    unsigned long jetzt = millis();

    vorherigerZustand = zustand;

    if (neuerRohzustand != rohzustand) {
      rohzustand = neuerRohzustand;
      wechselzeit = jetzt;
    }

    if (
      zustand != rohzustand &&
      jetzt - wechselzeit >= entprellzeit
    ) {
      zustand = rohzustand;
    }
  }

  bool aktiv() const {
    return zustand == LOW;
  }

  bool aktiviert() const {
    return vorherigerZustand == HIGH && zustand == LOW;
  }

  bool deaktiviert() const {
    return vorherigerZustand == LOW && zustand == HIGH;
  }

private:
  uint8_t pin;
  unsigned long entprellzeit;
  bool rohzustand;
  bool zustand;
  bool vorherigerZustand;
  unsigned long wechselzeit;
};

Eingang sensor(SENSOR_PIN, ENTPRELLZEIT_MS);
Eingang resetTaste(RESET_PIN, ENTPRELLZEIT_MS);

bool postVorhanden = false;
bool resetGestartet = false;
bool resetAusgefuehrt = false;

unsigned long resetStartzeit = 0;

uint8_t kontrollwert(uint8_t status) {
  return EEPROM_SIGNATUR ^ status ^ 0x69;
}

void ausgangAktualisieren() {
  digitalWrite(LED_PIN, postVorhanden ? HIGH : LOW);
}

void statusSpeichern() {
  Speicherwert neu = {
    EEPROM_SIGNATUR,
    postVorhanden ? 1 : 0,
    kontrollwert(postVorhanden ? 1 : 0)
  };

  Speicherwert alt;
  EEPROM.get(EEPROM_ADRESSE, alt);

  if (
    alt.signatur != neu.signatur ||
    alt.status != neu.status ||
    alt.kontrolle != neu.kontrolle
  ) {
    EEPROM.put(EEPROM_ADRESSE, neu);
  }
}

void statusLaden() {
  Speicherwert daten;
  EEPROM.get(EEPROM_ADRESSE, daten);

  bool gueltig =
    daten.signatur == EEPROM_SIGNATUR &&
    daten.status <= 1 &&
    daten.kontrolle == kontrollwert(daten.status);

  if (gueltig) {
    postVorhanden = daten.status == 1;
  } else {
    postVorhanden = false;
    statusSpeichern();
  }
}

void postMelden() {
  if (postVorhanden) {
    return;
  }

  postVorhanden = true;
  statusSpeichern();
  ausgangAktualisieren();
}

void postZuruecksetzen() {
  if (!postVorhanden) {
    return;
  }

  postVorhanden = false;
  statusSpeichern();
  ausgangAktualisieren();
}

void sensorVerarbeiten() {
  sensor.aktualisieren();

  if (sensor.aktiviert()) {
    postMelden();
  }
}

void resetVerarbeiten() {
  resetTaste.aktualisieren();

  unsigned long jetzt = millis();

  if (resetTaste.aktiviert()) {
    resetGestartet = true;
    resetAusgefuehrt = false;
    resetStartzeit = jetzt;
  }

  if (
    resetTaste.aktiv() &&
    resetGestartet &&
    !resetAusgefuehrt &&
    jetzt - resetStartzeit >= RESETZEIT_MS
  ) {
    postZuruecksetzen();
    resetAusgefuehrt = true;
  }

  if (resetTaste.deaktiviert()) {
    resetGestartet = false;
    resetAusgefuehrt = false;
  }
}

void setup() {
  pinMode(LED_PIN, OUTPUT);

  sensor.beginnen();
  resetTaste.beginnen();

  statusLaden();
  ausgangAktualisieren();
}

void loop() {
  sensorVerarbeiten();
  resetVerarbeiten();
}
